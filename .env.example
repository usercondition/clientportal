# Local: docker-compose.db.yml. Railway: add DATABASE_URL on the *web* service via variable reference from Postgres.
# Name must be exactly DATABASE_URL (no spaces). Remove old POSTGRES_URL values that pointed at a deleted database.
# The server also accepts DATABASE_PRIVATE_URL, POSTGRES_URL, then DATABASE_PUBLIC_URL (last resort; egress).
# Prefer private postgres.railway.internal — not the public *.proxy.rlwy.net URL.
DATABASE_URL=postgresql://clientportal:clientportal_dev_password@localhost:5432/clientportal
# Optional: force SSL for Postgres (default off for *.railway.internal; on for *.proxy.rlwy.net unless PGSSL=false)
# PGSSL=true
PORT=3000

# Set to true to skip applying 001_init.sql on startup when public.clients is missing.
# SKIP_AUTO_SCHEMA=true

# Email alerts (optional — requires SMTP)
# ADMIN_NOTIFY_EMAIL receives website contact-form emails and alerts when a client sends a message.
ADMIN_NOTIFY_EMAIL=m.e.mercado@proton.me
# Optional: Reply-To on emails TO clients (when staff replies). Defaults to ADMIN_NOTIFY_EMAIL if unset.
# ADMIN_REPLY_EMAIL=support@yourdomain.com
# Base URL of the deployed site (no trailing slash). Used in client emails for portal/admin links.
# Example: https://yoursite.com or your Railway public URL
PUBLIC_SITE_URL=
# When you add order status updates in the API, optional copy of those emails to admin:
# NOTIFY_ADMIN_ON_ORDER_STATUS=true
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=

# Optional sampler: auto-reply assistant in client chat (easy to disable/remove later).
# Set true to enable a basic first-response bot that posts clearly labeled "Support assistant (sample)" replies.
# SUPPORT_BOT_SAMPLER_ENABLED=true

# Optional: POST /api/admin/marketplace/sync (automation / custom tools only; no admin UI). Disabled by default.
# MARKETPLACE_SYNC_ENABLED=true
# MARKETPLACE_SYNC_TOKEN=replace-with-long-random-value
# MARKETPLACE_SYNC_MAX_PER_MIN=120
# GET /api/health includes marketplace.* when the DB is up.

# Stripe checkout (shop)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Defaults to "usd" if omitted
# STRIPE_CURRENCY=usd

# Client portal — quote review payment hints (PayPal, Venmo, Zelle, Cash App; public URLs / copy only).
# Unset values fall back to clientportal/lib/studio-payment-defaults.js.
# PORTAL_PAYMENT_BRAND=Steindahl 3D Group
# PORTAL_PAYPAL_URL=https://paypal.me/project35
# PORTAL_VENMO_URL=https://account.venmo.com/u/Miguel-Mercado-110
# PORTAL_CASH_APP_URL=https://cash.app/$Steindahl3DGroup
# PORTAL_ZELLE_NOTE=Send the full amount via Zelle to: your-zelle-email@example.com
# PORTAL_CASH_APP_TAG=$Steindahl3DGroup
# PORTAL_FULL_PAYMENT_ONLY=true
