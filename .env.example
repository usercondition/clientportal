# Local Postgres (docker-compose.db.yml). On Railway: reference Postgres's *private* URL on your web service —
# do NOT set DATABASE_URL to DATABASE_PUBLIC_URL (public TCP proxy → egress fees). Use the private DATABASE_URL
# (or DATABASE_PRIVATE_URL if shown) from the Postgres service variables.
DATABASE_URL=postgresql://clientportal:clientportal_dev_password@localhost:5432/clientportal
PORT=3000

# Email alerts for new inbox messages (optional — requires SMTP)
# ADMIN_NOTIFY_EMAIL receives alerts when a client sends a message (defaults in code if unset).
ADMIN_NOTIFY_EMAIL=m.e.mercado@proton.me
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
